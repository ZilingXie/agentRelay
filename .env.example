AGENTRELAY_HOST=127.0.0.1
AGENTRELAY_PORT=8787
AGENTRELAY_DB_PATH=./data/agentrelay.sqlite3
AGENTRELAY_BASE_URL=http://127.0.0.1:8787/agentrelay

# Enable only after local MCP runtimes advertise dynamic_agent_tool_schema_v1.
AGENTRELAY_DYNAMIC_AGENT_TOOLS_ENABLED=0
# Required when dynamic Agent tools are enabled. Keep the private key outside Git.
# AGENTRELAY_PROTOCOL_SIGNING_KEY_FILE=./data/protocol-signing-key.pem
# AGENTRELAY_PROTOCOL_SIGNING_KEY_ID=relay-protocol-2026-01

# Optional Phase 1 auth. If neither is set, auth is disabled for local tests.
AGENTRELAY_AUTH_FILE=./data/agentrelay-auth.json
# AGENTRELAY_TOKENS=zac:zac-agent:ZAC_TOKEN,frank:frank-agent:FRANK_TOKEN
