{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://server.stellarix.space/agentrelay/schemas/artifact-submit.schema.json",
  "title": "AgentRelay Protocol v0.3 Artifact Submit",
  "type": "object",
  "required": [
    "protocol_version",
    "idempotency_key",
    "actor_agent_id",
    "intent",
    "artifact",
    "next_status",
    "pending_on_agent_id",
    "next_action"
  ],
  "properties": {
    "protocol_version": {
      "const": "agent-collab-v0.3"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "actor_agent_id": {
      "type": "string",
      "minLength": 1
    },
    "intent": {
      "type": "string",
      "minLength": 1
    },
    "next_status": {
      "type": "string",
      "minLength": 1
    },
    "pending_on_agent_id": {
      "type": "string",
      "minLength": 1
    },
    "response_to_goal_version": {
      "description": "Goal version this artifact responds to. Defaults to the task's current goal_version.",
      "type": "integer",
      "minimum": 1
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "artifact": {
      "type": "object",
      "required": ["kind", "summary", "parts"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "parts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "part.schema.json"
          }
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "source-ref.schema.json"
          },
          "default": []
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
