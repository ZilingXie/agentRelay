{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://server.stellarix.space/agentrelay/schemas/protocol-v05-common.schema.json",
  "title": "AgentRelay Protocol v0.5 Common Objects",
  "$defs": {
    "parts": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "object", "minProperties": 1}
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id", "root_task_id", "protocol_version", "requester_agent_id",
        "target_agent_id", "done_criteria", "status", "turn_sequence",
        "current_message_id", "from_agent_id", "to_agent_id", "task_version",
        "max_turns", "task_expires_at", "reason", "terminal_by_agent_id",
        "completed_against_message_id", "created_at", "updated_at"
      ],
      "properties": {
        "task_id": {"type": "string", "minLength": 1},
        "root_task_id": {"type": "string", "minLength": 1},
        "protocol_version": {"const": "agent-collab-v0.5"},
        "requester_agent_id": {"type": "string", "minLength": 1},
        "target_agent_id": {"type": "string", "minLength": 1},
        "done_criteria": {"oneOf": [{"type": "string", "minLength": 1}, {"type": "object", "minProperties": 1}]},
        "status": {"enum": ["open", "completed", "expired", "failed"]},
        "turn_sequence": {"type": "integer", "minimum": 1},
        "current_message_id": {"type": "string", "minLength": 1},
        "from_agent_id": {"type": "string", "minLength": 1},
        "to_agent_id": {"type": "string", "minLength": 1},
        "task_version": {"type": "integer", "minimum": 1},
        "max_turns": {"type": "integer", "minimum": 1},
        "task_expires_at": {"type": "integer", "minimum": 1},
        "reason": {"type": ["string", "null"]},
        "terminal_by_agent_id": {"type": ["string", "null"]},
        "completed_against_message_id": {"type": ["string", "null"]},
        "created_at": {"type": "integer"},
        "updated_at": {"type": "integer"}
      }
    },
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "message_id", "task_id", "turn_sequence", "from_agent_id", "to_agent_id",
        "parts", "idempotency_key", "delivery_status", "max_delivery_attempts",
        "delivered_at", "failed_at", "delivery_reason", "created_at", "updated_at"
      ],
      "properties": {
        "message_id": {"type": "string", "minLength": 1},
        "task_id": {"type": "string", "minLength": 1},
        "turn_sequence": {"type": "integer", "minimum": 1},
        "from_agent_id": {"type": "string", "minLength": 1},
        "to_agent_id": {"type": "string", "minLength": 1},
        "parts": {"$ref": "#/$defs/parts"},
        "idempotency_key": {"type": "string", "minLength": 1},
        "delivery_status": {"enum": ["pending", "delivered", "failed"]},
        "max_delivery_attempts": {"const": 4},
        "delivered_at": {"type": ["integer", "null"]},
        "failed_at": {"type": ["integer", "null"]},
        "delivery_reason": {"type": ["string", "null"]},
        "created_at": {"type": "integer"},
        "updated_at": {"type": "integer"}
      }
    },
    "outbox": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id", "agent_id", "event_type", "task_id", "message_id",
        "idempotency_key", "outbox_status", "outbox_attempts", "inflight_until",
        "next_retry_at", "acked_at", "exhausted_at", "exhaustion_reason",
        "last_error", "can_transition_message", "created_at", "updated_at"
      ],
      "properties": {
        "event_id": {"type": "string", "minLength": 1},
        "agent_id": {"type": "string", "minLength": 1},
        "event_type": {"type": "string", "minLength": 1},
        "task_id": {"type": "string", "minLength": 1},
        "message_id": {"type": ["string", "null"]},
        "idempotency_key": {"type": "string", "minLength": 1},
        "outbox_status": {"enum": ["queued", "inflight", "acked", "retry_wait", "exhausted"]},
        "outbox_attempts": {"type": "integer", "minimum": 0, "maximum": 4},
        "inflight_until": {"type": ["integer", "null"]},
        "next_retry_at": {"type": ["integer", "null"]},
        "acked_at": {"type": ["integer", "null"]},
        "exhausted_at": {"type": ["integer", "null"]},
        "exhaustion_reason": {"type": ["string", "null"]},
        "last_error": {"type": ["string", "null"]},
        "can_transition_message": {"type": "boolean"},
        "created_at": {"type": "integer"},
        "updated_at": {"type": "integer"}
      }
    },
    "mutationContext": {
      "type": "object",
      "required": ["message_id", "turn_sequence", "expected_task_version", "idempotency_key"],
      "properties": {
        "message_id": {"type": "string", "minLength": 1},
        "turn_sequence": {"type": "integer", "minimum": 1},
        "expected_task_version": {"type": "integer", "minimum": 1},
        "idempotency_key": {"type": "string", "minLength": 1}
      }
    }
  }
}
