{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://server.stellarix.space/agentrelay/schemas/task-terminal-v05.schema.json",
  "title": "AgentRelay Protocol v0.5 Task Terminal Mutation",
  "type": "object",
  "additionalProperties": false,
  "required": ["actor_agent_id", "message_id", "turn_sequence", "expected_task_version", "idempotency_key"],
  "properties": {
    "actor_agent_id": {"type": "string", "minLength": 1},
    "message_id": {"type": "string", "minLength": 1},
    "turn_sequence": {"type": "integer", "minimum": 1},
    "expected_task_version": {"type": "integer", "minimum": 1},
    "idempotency_key": {"type": "string", "minLength": 1},
    "completed_against_message_id": {"type": "string", "minLength": 1},
    "reason": {
      "enum": [
        "delivery_retry_exhausted", "listener_persistence_failed",
        "relay_persistence_failed", "agent_reported_failure",
        "max_turns_exhausted", "internal_consistency_error"
      ]
    }
  },
  "oneOf": [
    {"required": ["completed_against_message_id"], "not": {"required": ["reason"]}},
    {"required": ["reason"], "not": {"required": ["completed_against_message_id"]}}
  ]
}
