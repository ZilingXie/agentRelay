{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://server.stellarix.space/agentrelay/schemas/agent-card.schema.json",
  "title": "AgentRelay A2A-Shaped Agent Card",
  "type": "object",
  "required": [
    "protocolVersion",
    "a2aProtocolVersion",
    "name",
    "description",
    "url",
    "provider",
    "capabilities",
    "skills",
    "agentRelay"
  ],
  "properties": {
    "protocolVersion": {
      "const": "agentrelay-agent-card-v0.3"
    },
    "a2aProtocolVersion": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "url": {
      "type": "string",
      "minLength": 1
    },
    "supportedInterfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["protocolBinding", "protocolVersion", "url"],
        "properties": {
          "protocolBinding": {
            "type": "string"
          },
          "protocolVersion": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "tenant": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "provider": {
      "type": "object",
      "required": ["organization"],
      "additionalProperties": true
    },
    "capabilities": {
      "type": "object",
      "required": ["streaming", "pushNotifications", "stateTransitionHistory"],
      "additionalProperties": true
    },
    "securitySchemes": {
      "type": "object",
      "additionalProperties": true
    },
    "securityRequirements": {
      "type": "array"
    },
    "defaultInputModes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "defaultOutputModes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "description"],
        "additionalProperties": true
      }
    },
    "agentRelay": {
      "type": "object",
      "required": [
        "agent_id",
        "owner",
        "agent_role",
        "execution_mode",
        "protocol_capabilities",
        "policy",
        "accepted_task_types",
        "scopes",
        "human_approval_policy",
        "endpoints"
      ],
      "properties": {
        "agent_role": {
          "enum": ["personal_agent", "service_agent"]
        },
        "execution_mode": {
          "enum": ["notify_only", "manual", "semi_auto", "autonomous"]
        },
        "protocol_capabilities": {
          "type": "array",
          "items": {"type": "string"}
        },
        "policy": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
